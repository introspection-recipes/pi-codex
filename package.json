{
  "name": "@introspection-recipes/pi-codex",
  "version": "0.1.1",
  "description": "OpenAI Codex CLI harness reproduced as an Introspection (Pi) recipe — a pi-codex starter template.",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "check": "npx -y -p @introspection-ai/pi-recipes@latest recipes check . --profile ci",
    "check:json": "npx -y -p @introspection-ai/pi-recipes@latest recipes check . --profile ci --json",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "pi": {
    "agents": [
      "./agents/*.yaml"
    ],
    "skills": [
      "./skills/**/SKILL.md"
    ],
    "extensions": [
      "./extensions/*.ts",
      "./extensions/*/index.ts"
    ]
  }
}
