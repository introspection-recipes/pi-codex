# Web search (Parallel AI Search API) — used by extensions/web-search.ts.
# gpt-5.5 supports a hosted web_search tool in Codex; on the Pi runtime that
# hosted tool is unavailable, so web_search is backed by Parallel AI instead.
# Get a key at https://parallel.ai
PARALLEL_API_KEY=

# Optional web_search tuning
# PARALLEL_SEARCH_PROCESSOR=base      # base | pro
# PARALLEL_SEARCH_MAX_RESULTS=5
